{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RCSA Control Library",
  "description": "Defines controls and their expected evidence types for RCSA assessment",
  "type": "object",
  "required": ["_meta", "controls"],
  "additionalProperties": false,
  "properties": {
    "_meta": {
      "type": "object",
      "required": ["scale", "note"],
      "properties": {
        "scale": { "type": "string", "enum": ["demo", "production"] },
        "note": { "type": "string" }
      }
    },
    "controls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "objective", "evidence_types"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Z]{2,4}$",
            "description": "Short uppercase identifier (e.g., AC, CM, DQ, IH)"
          },
          "name": { "type": "string" },
          "objective": { "type": "string" },
          "evidence_types": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": ["id", "label", "description"],
              "additionalProperties": false,
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_]*$",
                  "description": "Snake_case identifier"
                },
                "label": { "type": "string" },
                "description": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
