{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RCSA Artifact Index",
  "description": "Index of codebase artifacts that serve as evidence for RCSA controls",
  "type": "object",
  "required": ["_meta", "artifacts"],
  "additionalProperties": false,
  "properties": {
    "_meta": {
      "type": "object",
      "required": ["scale", "note"],
      "properties": {
        "scale": { "type": "string", "enum": ["demo", "production"] },
        "note": { "type": "string" }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "file_path", "file_type", "description"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^ART-\\d{3}$",
            "description": "Unique identifier (e.g., ART-001)"
          },
          "file_path": {
            "type": "string",
            "pattern": "^(?!\\/)",
            "description": "Relative file path — must not start with /"
          },
          "file_type": { "type": "string" },
          "description": { "type": "string" },
          "lines": {
            "type": "string",
            "pattern": "^\\d+-\\d+$",
            "description": "Optional line range (e.g., 1-42)"
          }
        }
      }
    }
  }
}
